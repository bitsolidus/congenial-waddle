# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection (Atlas or self-hosted)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/crypto_trading_platform

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Admin Credentials
ADMIN_EMAIL=admin@cryptoplatform.com
ADMIN_PASSWORD=admin123

# Frontend URL
FRONTEND_URL=https://bitsolidus.io

# Email Configuration (SendGrid)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
FROM_EMAIL=noreply@bitsolidus.io
FROM_NAME=BitSolidus

# Blockchain RPC URLs (Optional)
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org/
POLYGON_RPC_URL=https://polygon-rpc.com/

# Gas Settings
DEFAULT_GAS_MULTIPLIER=1.5
DEFAULT_GAS_LIMIT=21000

# Uploads Directory (optional - for Docker persistence)
# In Docker: set to /app/uploads
# Local development: leave empty or set to ./uploads
UPLOADS_DIR=
